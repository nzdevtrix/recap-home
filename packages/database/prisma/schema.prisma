datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== ENUMS ====================

enum UserRole {
  PRIVATE
  RIDER
  BUSINESS
  DEVELOPER
  SYSTEM_OPERATOR
  CUSTOMER_CARE
  REGIONAL_OPERATOR
  LOCAL_RIDER_MONITOR
}

enum OrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum RiderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessStatus {
  PENDING_BANKING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum BusinessLegalType {
  INDIVIDUALE
  SNC
  SAS
  SRL
  SRLS
  SPA
  SAPA
  COOPERATIVA
  CONSORZIO
  ONLUS
  FREELANCE
  ALTRO
}

enum DocumentType {
  IDENTITY_FRONT
  IDENTITY_BACK
  PERMESSO_SOGGIORNO
  TESSERA_SANITARIA
  BANK_PROOF
}

enum BusinessCategory {
  RISTORAZIONE
  FAST_FOOD
  BAR
  GELATERIA
  PASTICCERIA
  PANIFICIO
  RISTORANTE
  PIZZERIA
  RISTORANTE_ETNICO
  AGRITURISMO
  SUPERMERCATO
  IPERMERCATO
  DISCOUNT
  MINIMERCATO
  NEGOZIO_ALIMENTARI
  MACELLERIA
  PESCHERIA
  ORTOFRUTTA
  FORMAGGIO
  SALUMERIA
  ENOTECA
  OLIO
  GASTRONOMIA
  RISTORAZIONE_COLLETTIVA
  CATERING
  COMMERCIO_ELETTRONICO
  PRODOTTI_BIOLOGICI
  ALIMENTI_ANIMALI
  BEVANDE
  ALTRO
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  username      String?   @unique
  name          String?
  firstName     String?
  lastName      String?
  role          UserRole  @default(PRIVATE)

  googleId      String?   @unique
  googleImage   String?
  emailVerified Boolean   @default(false)
  emailToken    String?
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rider             RiderProfile?
  business          BusinessProfile?
  orders            Order[]
  sessions          Session[]
  documents         Document[]
  bankingInfo       BankingInfo?
  sentMessages      ChatMessage[]     @relation("SentMessages")
  receivedMessages  ChatMessage[]     @relation("ReceivedMessages")
  conversations     Conversation[]
  notifications     Notification[]

  @@map("users")
}

model Document {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        DocumentType
  url         String
  verified    Boolean      @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@map("documents")
}

model BankingInfo {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  iban          String
  bicSwift      String
  accountHolder String
  bankName      String?
  bankProofDoc  String?
  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("banking_info")
}

model RiderProfile {
  id          String              @id @default(uuid())
  userId      String              @unique
  user        User                @relation(fields: [userId], references: [id])

  fullName          String
  dateOfBirth       DateTime
  placeOfBirth      String
  nationality       String
  codiceFiscale     String
  residenceAddress  String
  domicileAddress   String?
  desiredWorkCity   String
  hasBusiness       Boolean         @default(false)
  vatId             String?
  hasPermessoDiSoggiorno Boolean    @default(false)

  approvalStatus    RiderApprovalStatus @default(PENDING)
  approvedById      String?
  approvedAt        DateTime?
  rejectionReason   String?
  reviewedAt        DateTime?

  licenseNumber     String?
  licenseImage      String?
  vehicleType       String?
  vehiclePlate      String?
  vehicleColor      String?

  regionId          String
  isAvailable       Boolean         @default(false)
  currentShiftId    String?
  rating            Float           @default(0)
  totalRatings      Int             @default(0)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  orders            Order[]
  shifts            RiderShift[]

  @@map("rider_profiles")
}

model BusinessProfile {
  id          String           @id @default(uuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id])

  legalName         String
  legalType         BusinessLegalType
  ownerFullName     String
  ownerDob          DateTime
  ownerPlaceOfBirth String
  ownerCodiceFiscale String
  ownerResidence    String
  pecAddress        String?
  vatId             String
  businessCategory  BusinessCategory
  businessAddress   String
  city              String?
  postalCode        String?
  phone             String?
  website           String?

  status            BusinessStatus   @default(PENDING_BANKING)
  approvedAt        DateTime?
  isVerified        Boolean          @default(false)
  verificationDocs  String?
  isOpen            Boolean          @default(false)
  openingHours      String?
  rating            Float            @default(0)
  totalRatings      Int              @default(0)

  regionId          String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  products          Product[]
  orders            Order[]
  paymentConfig     PaymentConfig?

  @@map("business_profiles")
}

model Product {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  price       Float
  category    String
  subCategory String?
  imageUrl    String?
  images      Json?
  isAvailable Boolean  @default(true)
  stock       Int?     @default(0)
  options     Json?
  tags        Json?
  rating      Float    @default(0)
  totalRatings Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    BusinessProfile @relation(fields: [businessId], references: [id])

  @@map("products")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sessions")
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @default(uuid())
  userId          String
  businessId      String?
  riderId         String?
  items           Json
  total           Float
  deliveryFee     Float       @default(0)
  grandTotal      Float
  status          OrderStatus @default(PENDING)
  pickupAddress   String
  deliveryAddress String
  deliveryNotes   String?
  paymentMethod   String?
  paymentStatus   String      @default("PENDING")
  paymentId       String?
  paymentAmount   Float?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  userRating      Int?
  riderRating     Int?
  businessRating  Int?

  user     User             @relation(fields: [userId], references: [id])
  business BusinessProfile? @relation(fields: [businessId], references: [id])
  rider    RiderProfile?    @relation(fields: [riderId], references: [id])

  @@map("orders")
}

model Region {
  id         String   @id @default(uuid())
  name       String   @unique
  code       String   @unique
  boundaries Json
  center     Json?
  isActive   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("regions")
}

model RiderShift {
  id        String   @id @default(uuid())
  riderId   String
  startTime DateTime
  endTime   DateTime
  isActive  Boolean  @default(true)
  rider     RiderProfile @relation(fields: [riderId], references: [id])

  @@map("rider_shifts")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  isSent    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model PaymentConfig {
  id          String   @id @default(uuid())
  businessId  String   @unique
  acceptsCreditCard Boolean @default(true)
  acceptsPayPal     Boolean @default(true)
  acceptsSatispay  Boolean @default(true)
  acceptsCash       Boolean @default(true)
  stripePublishableKey String?
  stripeSecretKey      String?
  stripeWebhookSecret  String?
  paypalClientId      String?
  paypalClientSecret  String?
  paypalWebhookId     String?
  satispayApiKey      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id])

  @@map("payment_configs")
}

model ChatMessage {
  id        String   @id @default(uuid())
  conversationId String
  senderId  String
  receiverId String?
  message   String
  isAi      Boolean  @default(false)
  orderId   String?
  role      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  sender    User         @relation("SentMessages", fields: [senderId], references: [id])
  receiver  User?        @relation("ReceivedMessages", fields: [receiverId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("chat_messages")
}

model Conversation {
  id         String       @id @default(uuid())
  userId     String
  orderId    String?
  isOpen     Boolean      @default(true)
  isResolved Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user      User          @relation(fields: [userId], references: [id])
  messages  ChatMessage[]

  @@map("conversations")
}